---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---
<Layout title="404 — Enis Mulić">
  <Nav />
  <main style="display:grid;place-items:center;min-height:100vh;text-align:center;">
    <div>
      <p style="font-size:0.78rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;">404</p>
      <h1 style="font-size:2rem;margin-bottom:0.75rem;">Page not found</h1>
      <a href="/" style="font-size:0.88rem;color:var(--accent);border-bottom:1px solid currentColor;padding-bottom:1px;">Go home</a>
    </div>
  </main>
</Layout>
