---
import { experience } from '../../data/experience';
import { projects } from '../../data/projects';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const all = [
  ...experience.map(item => ({
    slug: item.slug,
    name: item.title,
    summary: item.summary,
    stack: item.stack,
    extUrl: item.caseStudyUrl,
  })),
  ...projects.map(project => ({
    slug: project.slug,
    name: project.name,
    summary: project.summary,
    stack: project.stack,
    extUrl: project.liveUrl,
  })),
];
---

<Layout title="Projects — Enis Mulić" description="All projects — work at RUBICON and personal builds.">
  <Nav />
  <main>
    <div class="container">
      <a href="/" class="back">← Back</a>
      <div class="grid">
        {all.map(item => (
          <article>
            <a href={`/projects/${item.slug}`} class="card-link" aria-label={item.name} />
            <div class="name-row">
              <h3>{item.name}</h3>
              {item.extUrl && (
                <a href={item.extUrl} target="_blank" rel="noopener" class="ext-link">↗</a>
              )}
            </div>
            <p class="desc">{item.summary}</p>
            <div class="tags">
              {item.stack.map(s => <span class="tag">{s}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    padding-top: calc(4rem + 72px);
    padding-bottom: 6rem;
  }

  .back {
    display: inline-block;
    font-size: 0.82rem;
    color: var(--muted);
    margin-bottom: 3rem;
    transition: color 0.15s;
  }

  .back:hover { color: var(--fg); }

  .grid {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--subtle);
    border-radius: 8px;
    overflow: hidden;
    background: var(--subtle);
  }

  article {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
    background: #161616;
    transition: background 0.15s;
    cursor: pointer;
  }

  article:hover { background: #1b1b1b; }

  .card-link {
    position: absolute;
    inset: 0;
    display: block;
    z-index: 0;
  }

  .name-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--fg);
    line-height: 1.3;
  }

  .ext-link {
    position: relative;
    z-index: 1;
    font-size: 1rem;
    color: var(--muted);
    flex-shrink: 0;
    line-height: 1.3;
    transition: color 0.15s;
  }

  .ext-link:hover { color: var(--accent); }

  .desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
</style>
