---
import { items } from '../../data/items';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

export function getStaticPaths() {
  return items.map(item => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<Layout title={`${item.name} — Enis Mulić`} description={item.summary}>
  <Nav />
  <main>
    <div class="container">
      <a href="/projects" class="back">← Projects</a>

      <header>
        <p class="type-label">{item.type === 'work' ? 'RUBICON d.o.o.' : 'Personal Project'}</p>
        <h1>{item.name}</h1>
        <div class="meta">
          {item.role && <span class="subtitle">{item.role}</span>}
          {item.period && <span class="period">{item.period}</span>}
        </div>
        <div class="ext-links">
          {item.extUrl && (
            <a href={item.extUrl} target="_blank" rel="noopener" class="external">
              {item.extLabel ?? item.extUrl} ↗
            </a>
          )}
          {item.githubUrl && (
            <a href={item.githubUrl} target="_blank" rel="noopener" class="external">
              GitHub ↗
            </a>
          )}
        </div>
      </header>

      <p class="summary">{item.summary}</p>

      <ul class="bullets">
        {item.description.map((b: string) => <li>{b}</li>)}
      </ul>

      <div class="stack">
        {item.stack.map((s: string) => <span class="tag">{s}</span>)}
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    padding-top: calc(4rem + 72px);
    padding-bottom: 6rem;
  }

  .back {
    display: inline-block;
    font-size: 0.82rem;
    color: var(--muted);
    margin-bottom: 3rem;
    transition: color 0.15s;
  }

  .back:hover { color: var(--fg); }

  header { margin-bottom: 2.5rem; }

  .type-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    margin-bottom: 0.6rem;
    color: var(--fg);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 0.875rem;
    color: var(--muted);
    font-style: italic;
  }

  .period {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .ext-links { display: flex; flex-wrap: wrap; gap: 1.25rem; }

  .external {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--accent);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: opacity 0.15s;
  }

  .external:hover { opacity: 0.75; color: var(--accent); }

  .summary {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--muted);
    max-width: 60ch;
    margin-bottom: 2.5rem;
    border-left: 2px solid var(--subtle);
    padding-left: 1.25rem;
  }

  .bullets {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
    list-style: disc;
    padding-left: 1.25rem;
  }

  .bullets li {
    font-size: 0.925rem;
    color: var(--muted);
    line-height: 1.7;
    padding-left: 0.25rem;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
