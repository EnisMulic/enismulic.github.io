---
import { projects } from '../data/projects';
import type { Project } from '../data/projects';
---
<section id="projects">
  <div class="container">
    <div class="grid">
      {projects.map((project: Project) => (
        <article>
          <div class="card-top">
            <div class="name-row">
              <h3>{project.name}</h3>
              {project.liveUrl && (
                <a href={project.liveUrl} target="_blank" rel="noopener" class="live-link" aria-label={`Visit ${project.name}`}>↗</a>
              )}
            </div>
            {project.liveUrl && (
              <a href={project.liveUrl} target="_blank" rel="noopener" class="tagline">{project.tagline}</a>
            )}
          </div>
          <p class="desc">{project.summary}</p>
          <div class="tags">
            {project.stack.map((s: string) => (
              <span class="tag">{s}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--subtle);
    border-radius: 8px;
    overflow: hidden;
    background: var(--subtle);
  }

  article {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: #161616;
    transition: background 0.15s;
  }

  article:hover { background: #1b1b1b; }

  .card-top { display: flex; flex-direction: column; gap: 0.3rem; }

  .name-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--fg);
    line-height: 1.3;
  }

  .live-link {
    font-size: 1rem;
    color: var(--muted);
    flex-shrink: 0;
    transition: color 0.15s;
    line-height: 1.3;
  }

  .live-link:hover { color: var(--accent); }

  .tagline {
    font-size: 0.75rem;
    color: var(--muted);
    transition: color 0.15s;
  }

  .tagline:hover { color: var(--accent); }

  .desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }
</style>
