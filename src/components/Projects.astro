---
import { items } from '../data/items';
import type { Item } from '../data/items';

const featured = items.filter(i => i.featured);
---

<section id="projects">
  <div class="container">
    <div class="grid">
      {featured.map((item: Item) => (
        <article>
          <a href={`/projects/${item.slug}`} class="card-link" aria-label={item.name} />
          <div class="card-top">
            <div class="name-row">
              <h3>{item.name}</h3>
              {item.extUrl && (
                <a href={item.extUrl} target="_blank" rel="noopener" class="ext-link" aria-label={`Visit ${item.name}`}>↗</a>
              )}
            </div>
            {item.role && (
              <div class="meta">
                <span class="role">{item.role}</span>
              </div>
            )}
          </div>
          <p class="desc">{item.summary}</p>
          <div class="tags">
            {item.stack.map((s: string) => (
              <span class="tag">{s}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
    <a href="/projects" class="view-all">View all projects →</a>
  </div>
</section>

<style>
  section { padding-top: 0; padding-bottom: 6rem; }

  .grid {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--subtle);
    border-radius: 8px;
    overflow: hidden;
    background: var(--subtle);
  }

  article {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: #161616;
    transition: background 0.15s;
    cursor: pointer;
  }

  article:hover { background: #1b1b1b; }

  .card-link {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
  }

  .card-top { display: flex; flex-direction: column; gap: 0.4rem; }

  .name-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--fg);
    line-height: 1.3;
  }

  .ext-link {
    position: relative;
    z-index: 1;
    font-size: 1rem;
    color: var(--muted);
    flex-shrink: 0;
    line-height: 1.3;
    transition: color 0.15s;
  }

  .ext-link:hover { color: var(--accent); }

  .meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .role {
    font-size: 0.75rem;
    color: var(--muted);
    font-style: italic;
  }

  .desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  .view-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.15s;
  }

  .view-all:hover { color: var(--fg); }
</style>
