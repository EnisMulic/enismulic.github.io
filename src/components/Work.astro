---
import { experience } from '../data/experience';
import type { ExperienceItem } from '../data/experience';
import { projects } from '../data/projects';
import type { Project } from '../data/projects';
---

<section id="work">
  <div class="container">
    <div class="grid">
      {experience.map((item: ExperienceItem) => (
        <article>
          <div class="card-top">
            <div class="name-row">
              <h3>{item.title}</h3>
              {item.caseStudyUrl && (
                <a href={item.caseStudyUrl} target="_blank" rel="noopener" class="ext-link" aria-label={`Case study for ${item.title}`}>↗</a>
              )}
            </div>
            <div class="meta">
              <span class="role">{item.role}</span>
              <span class="period">{item.period}</span>
            </div>
          </div>
          <p class="desc">{item.summary}</p>
          <div class="tags">
            {item.stack.map((s: string) => (
              <span class="tag">{s}</span>
            ))}
          </div>
        </article>
      ))}
      {projects.map((project: Project) => (
        <article>
          <div class="card-top">
            <div class="name-row">
              <h3>{project.name}</h3>
              {project.liveUrl && (
                <a href={project.liveUrl} target="_blank" rel="noopener" class="ext-link" aria-label={`Visit ${project.name}`}>↗</a>
              )}
            </div>
            {project.liveUrl && (
              <a href={project.liveUrl} target="_blank" rel="noopener" class="tagline">{project.tagline}</a>
            )}
          </div>
          <p class="desc">{project.summary}</p>
          <div class="tags">
            {project.stack.map((s: string) => (
              <span class="tag">{s}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  section { padding-top: 0; padding-bottom: 0; }

  .grid {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--subtle);
    border-radius: 8px;
    overflow: hidden;
    background: var(--subtle);
  }

  article {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: #161616;
    transition: background 0.15s;
  }

  article:hover { background: #1b1b1b; }

  .card-top { display: flex; flex-direction: column; gap: 0.4rem; }

  .name-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--fg);
    line-height: 1.3;
  }

  .ext-link {
    font-size: 1rem;
    color: var(--muted);
    flex-shrink: 0;
    line-height: 1.3;
    transition: color 0.15s;
  }

  .ext-link:hover { color: var(--accent); }

  .meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .role {
    font-size: 0.75rem;
    color: var(--muted);
    font-style: italic;
  }

  .period {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.02em;
    margin-left: auto;
  }

  .tagline {
    font-size: 0.75rem;
    color: var(--muted);
    transition: color 0.15s;
  }

  .tagline:hover { color: var(--accent); }

  .desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
</style>
