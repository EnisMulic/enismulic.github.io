---
import { skills } from '../data/skills';
import type { SkillGroup } from '../data/skills';
---
<section id="skills">
  <div class="container">
    <p class="section-label">Technical Skills</p>
    <dl>
      {skills.map((group: SkillGroup) => (
        <div class="row">
          <dt>{group.category}</dt>
          <dd>{group.items.join(', ')}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  dl { display: flex; flex-direction: column; gap: 0; }

  .row {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1rem;
    padding-block: 1rem;
    border-top: 1px solid var(--subtle);
    align-items: baseline;
  }

  .row:last-child { border-bottom: 1px solid var(--subtle); }

  dt {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--fg);
    text-transform: uppercase;
  }

  dd {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
  }

  @media (max-width: 560px) {
    .row { grid-template-columns: 1fr; gap: 0.3rem; }
  }
</style>
